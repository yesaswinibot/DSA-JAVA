class Solution {
    public void moveZeroes(int[] nums){
        int n=nums.length;
        int position=0;
        for(int i=0;i<n;i++){
            if(nums[i]!=0){
                nums[position]=nums[i];
                position++;
            }
        }
        for(int i=position;i<n;i++){
            nums[i]=0;
        }
    
        
    }
}
